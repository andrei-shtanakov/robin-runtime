# ROBIN-SPEC slot 17: secrets live in env / a secret manager, NEVER in the KB.
# Full VPS reference (with descriptions): deploy/env.example
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=            # voice (STT/TTS); empty = text-only

# Mounts (slot 5). Default resolves to the sibling prograph-vault; override if relocated.
#ROBIN_VAULT=/srv/robin/mirrors/prograph-vault
#ROBIN_VAR_DIR=

# slot 7: chat identity registry — comma-separated Telegram user ids (or @usernames).
ROBIN_ALLOWED_DM=
ROBIN_TELEGRAM_CHANNEL=    # digest destination
ROBIN_MAINTAINER_CHAT=     # liveness alerts (DM chat id)
ROBIN_WEB_TOKEN=           # bearer token for the web chat

# §7 cost caps + schedule
ROBIN_DAILY_BUDGET_USD=5
ROBIN_USER_DAILY_MSGS=30
ROBIN_TZ=UTC
