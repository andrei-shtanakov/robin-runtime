# /srv/robin/robin.env — ROBIN-SPEC slot 17: secrets live HERE (chmod 600), never in the KB.
# NOTE: systemd EnvironmentFile does NOT strip inline comments — keep comments on their
# own lines; everything after `=` becomes the value.

# --- secrets ---
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
# STT/TTS (voice); leave empty to run text-only:
OPENAI_API_KEY=
# bearer token for the web chat page:
ROBIN_WEB_TOKEN=

# --- mounts (slot 5): VPS mirror layout ---
ROBIN_VAULT=/srv/robin/mirrors/prograph-vault
ROBIN_VAR_DIR=/srv/robin/var

# --- identity & destinations (slot 7 / duty #2) ---
# comma-separated Telegram user ids (recommended) or @usernames:
ROBIN_ALLOWED_DM=
# digest destination: @channelname or -100… id (empty = persist digests locally only):
ROBIN_TELEGRAM_CHANNEL=
# DM chat id for liveness alerts:
ROBIN_MAINTAINER_CHAT=
# slot 8 passive-capture scope (M3 ambient context): comma-separated group chat ids or
# @names whose messages Robin keeps for @mention context. MUST be disclosed to the team
# (§6.5). Requires BotFather privacy mode OFF. Empty = capture off:
ROBIN_CAPTURE_CHATS=

# --- §7 caps & schedule ---
ROBIN_DAILY_BUDGET_USD=5
ROBIN_USER_DAILY_MSGS=30
# duties.md TZ — ecosystem working timezone (QUESTIONS.md #3, resolved 2026-07-10)
ROBIN_TZ=Asia/Tbilisi
ROBIN_DIGEST_GRACE_HOURS=6

# --- optional overrides ---
#ROBIN_MODEL=claude-opus-4-8
#ROBIN_WEB_PORT=8080
#ROBIN_HISTORY_TURNS=10
# slot 13: ambient context size N (channel messages fed to a group mention)
#ROBIN_AMBIENT_N=10
# voice models: alias or dated snapshot — must be enabled for the OpenAI project
# (check: curl -s https://api.openai.com/v1/models -H "Authorization: Bearer $OPENAI_API_KEY")
#ROBIN_STT_MODEL=whisper-1
#ROBIN_TTS_MODEL=gpt-4o-mini-tts
#ROBIN_TTS_VOICE=alloy
