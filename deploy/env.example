# /srv/robin/robin.env — ROBIN-SPEC slot 17: secrets live HERE (chmod 600), never in the KB.

# --- secrets ---
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=            # STT/TTS (voice); leave empty to run text-only
ROBIN_WEB_TOKEN=           # bearer token for the web chat page

# --- mounts (slot 5): VPS mirror layout ---
ROBIN_VAULT=/srv/robin/mirrors/prograph-vault
ROBIN_VAR_DIR=/srv/robin/var

# --- identity & destinations (slot 7 / duty #2) ---
ROBIN_ALLOWED_DM=          # comma-separated Telegram user ids (recommended) or @usernames
ROBIN_TELEGRAM_CHANNEL=    # digest destination: @channelname or -100… id
ROBIN_MAINTAINER_CHAT=     # DM chat id for liveness alerts

# --- §7 caps & schedule ---
ROBIN_DAILY_BUDGET_USD=5
ROBIN_USER_DAILY_MSGS=30
ROBIN_TZ=UTC               # duties.md <TZ> — set to the team timezone!
ROBIN_DIGEST_GRACE_HOURS=6

# --- optional overrides ---
#ROBIN_MODEL=claude-opus-4-8
#ROBIN_WEB_PORT=8080
#ROBIN_TTS_VOICE=alloy
#ROBIN_HISTORY_TURNS=10
